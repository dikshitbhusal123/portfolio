# Atlas: Database → Connect → Drivers. Under Network Access, allow your IP or 0.0.0.0/0 for Render/Vercel backends.
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/portfolio?appName=Cluster0
PORT=5001
JWT_SECRET=random-long-secret-string-at-least-32-chars

# Comma-separated browser origins allowed to call the API (fixes CORS on Vercel / Render).
# Example: https://your-app.vercel.app,https://your-preview-xxxxx.vercel.app
CORS_ORIGINS=

# Optional: allow any deployed https URL on *.vercel.app (easy for previews; tighten for production).
CORS_ALLOW_VERCEL_PREVIEWS=false

# If you omit CORS_ORIGINS entirely, one legacy demo origin is merged in repo defaults; otherwise set URLs above.
